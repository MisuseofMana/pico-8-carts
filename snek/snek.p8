pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
speed,go,sl,h,pwr = 10,true,1,1,false
oroborus = false

snek = {
	x=0,
	y=0,
	d=3,
	c=30,
	f=2,
	xf=false,
	yf=false
}

snekbod = {}
apples = {}

function _init()
	cls()
	map()
	music(0)
end

function _update()
	
	if btn(0) and snek.d ~= 1 then
		snek.d = 0
	elseif btn(1) and snek.d ~= 0 then
		snek.d = 1
	elseif btn(2) and snek.d ~= 3 then
		snek.d = 2
	elseif btn(3) and snek.d ~= 2 then
		snek.d = 3
	end

	if btn(4) then
		pal(3,5)
		pal(11,6)
		pwr = true
	else
		pal()
		pwr = false
	end
end

function makebody(dc)
	p = {
		f=snek.f+2,
		x=snek.x,
		y=snek.y,
		xf=false,
		yf=false,
		d=dc
	}
	
	if (#snekbod > 0) then
	 dl = snekbod[#snekbod].d
	end

	if dc ~= dl then
		if (dl == 1 and dc == 3) or (dl == 2 and dc == 0) then
			p.f = 20
		elseif (dl == 1 and dc == 2) or (dl == 3 and dc == 0) then
			p.f = 36
		elseif (dl == 0 and dc == 3) or (dl == 2 and dc == 1) then
			p.f = 19
		elseif (dl == 0 and dc == 2) or (dl == 3 and dc == 1) then
			p.f = 35
		end
		
	end


	return p 	
end

function move()
	if (snek.d == 0) snek.x -= 8 snek.xf = false snek.f = 1
	if (snek.d == 1) snek.x += 8 snek.xf = true snek.f = 1
	if (snek.d == 2) snek.y -= 8 snek.yf = true snek.f = 2
	if (snek.d == 3) snek.y += 8 snek.yf = false snek.f = 2

	if snek.x < 0 then snek.x = 120 end
	if snek.x > 127 then snek.x = 0 end
	if snek.y < 0 then snek.y = 120 end
	if snek.y > 127 then snek.y = 0 end
	spr(snek.f,snek.x,snek.y,1,1,snek.xf,snek.yf)
	drawbody()
end 

function drawbody()
	for i in all(snekbod) do
		spr(i.f,i.x,i.y,1,1,i.xf,i.yf)
	end
	
	if (#snekbod > sl) deli(snekbod,h)
end

function drawapples()
	while #apples < 5 do
		local tx = flr(rnd(16))*8
		local ty = flr(rnd(16))*8
		if mget(tx\8,ty\8) == 0 then
			a = {
				f=17,
				x=tx,
				y=ty
			}
			add(apples,a)	
		end
		
	end
	for i in all(apples) do
		spr(i.f,i.x,i.y,1,1,false,false)
	end
end

function checkcollself()
	local front = 0

	for i in all(snekbod) do
		print(i == snekbod[#snekbod],0,120)
		
		if snek.x\8 == i.x\8 and snek.y\8 == i.y\8 then
			front += 1
			if i.x\8 == snek.x\8 and i.y\8 == snek.y\8 then
				oroborus = true
			end
		end
	end
	
	if front > 0 and not pwr then
		go = false
	end
end

function checkcollapple()
	for i in all(apples) do
		if snek.x\8 == i.x\8 and snek.y\8 == i.y\8 then
			sl += 1
			speed -= .25
			sfx(0)
			del(apples,i)
		end
	end
	
	if (speed == 8) music(-1) music(1)
	if (speed == 5) music(-1) music(2)
	if (speed == 2) music(-1) music(3)
end

function gameover()
	if oroborus then
		cls()
		sfx(-1)
		spr(72,32,32,8,8,false,false)
		print("you ate your own tail\n great job",32,64)
	else
		cls()
		print("gameover\npress x to retry",32,54)
		
	end
end

function _draw()

	if go and not oroborus then
		if snek.c < speed then
			snek.c += 1 
		else
			cls()
			snek.c = 0
			add(snekbod, makebody(snek.d))
			move()
			drawapples()
			checkcollself()
			checkcollapple()
			map()
			print(#snekbod + 1,64,110)		
		end	
 	else
		gameover()
		music(-1)
	end
	
	if (btnp(❎) and not go) extcmd("reset")
	

end 
