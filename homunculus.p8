pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--hunkmunculus♥
--by shinbone
function _init()
	reading=false
	update_scene=update_menu
	draw_scene=draw_menu
	
	--update order
	up_order = {
		update_menu,
		update_story,
		update_level,
	}
	--draw order
	drw_order = {
		draw_menu,
		draw_story,
		draw_level,
	}
	--player data
	p={
		x=8,
		y=64,
		sprt=16,
		hp=3,
		xhp=3,
		move=1,
		scene=1
	}
	regstr_scene()
end

function regstr_scene()
	update_scene=up_order[p.scene]
	draw_scene=drw_order[p.scene]
end

function _update()
	update_scene()
end

function _draw()
	cls()
	draw_scene()
end
-->8
--update function
tsize=8

function update_menu()
 if btnp(❎) then
 	sfx(0)
 	draw_scene=draw_story
 	update_scene=update_story
 end
end

function update_story()
	if not reading then
		tb_init(0,{	
[[you are a homunculus, newly
made. your creator has very
high hopes for you.]],
[[unlike most homunculi, you
have a clear purpose. your
creator has only one request.]],
[[you must learn all you can
about love ♥♥♥]]
})
	elseif reading then
		tb_update()
	end
end

function update_level()
	local function msfx()
		local sound = rnd({1,2,3})
		sfx(sound)
	end
	
	-- move ⬅️ and ➡️
	if btnp(➡️) then
		p.x+=p.move*tsize
		msfx()
	end
	if btnp(⬅️) then
		p.x-=p.move*tsize
		msfx()
	end
	
	-- move ⬆️ and ⬇️
	if btnp(⬇️) then
		p.y+=p.move*tsize
		msfx()
	end
	if btnp(⬆️) then
	 p.y-=p.move*tsize
		msfx()
	end
end
-->8
--draw functions
function draw_menu()
	spr(16,60,25)
	print('♥ hunk-munculus ♥',27,40,8)
	print('learns about homuncu-love.',14,50,5)
	print('press ❎/x to start',26,74,13)
end

function draw_story()
	tb_draw()
	print('skip ❎/x', 0,100,13)
	print('next ➡️', 100,100,13)
end

function draw_level()
	local function load_level(lvl)
		map(0,0,0,40,16,7)
		spr(p.sprt,p.x,p.y)
	end
	
	load_level()
end
-->8
--storytelling
function tb_init(voice,string)
 reading=true
 tb={
  str=string,
  voice=voice,
  i=1,
  cur=0,
  char=0,
  x=0, -- x coordinate
  y=106, -- y coordginate
  w=127, -- text box width
  h=21, -- text box height
  col1=1, -- background color
  col2=13, -- border color
  col3=7  -- text color
 }
end

function tb_update()
	local strlen=#tb.str[tb.i]
	--[[
		if not finished printing
		increase cur by 0.9
	]]
 if tb.char<strlen then
  tb.cur+=0.9
 end
 
 --[[
 	animate typing and play voice
 	sfx
 ]]
 if tb.cur>0.9 then
  tb.char+=1
  tb.cur=0
  if (ord(tb.str[tb.i],tb.char)!=32) sfx(tb.voice)
 end
 
 if btnp(➡️) then
 	-- if not finished typing
 	if tb.char<strlen then
 	 -- skip typing
 		tb.char=strlen
 	elseif tb.char==strlen then
 		if #tb.str>tb.i then
   	tb.i+=1
   	tb.cur=0
   	tb.char=0
  	else
   	reading=false
   	p.scene+=1
   	regstr_scene()
   end
  end
 end
end

function tb_draw()
 if reading then
  rectfill(tb.x,tb.y,tb.x+tb.w,tb.y+tb.h,tb.col1)
  rect(tb.x,tb.y,tb.x+tb.w,tb.y+tb.h,tb.col2)
  print(sub(tb.str[tb.i],1,tb.char),tb.x+2,tb.y+2,tb.col3)
 end
end
