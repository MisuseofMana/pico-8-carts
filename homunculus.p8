pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--hunkmunculus♥
--by shinbone
draw_scene=nil
update_scene=nil

function _init()
	--update order
	up_order = {
		update_menu,
		update_story,
		update_level,
	}
	--draw order
	drw_order = {
		draw_menu,
		draw_story,
		draw_level,
	}
	--player data
	p={
		x=8,
		y=64,
		sprt=16,
		hp=3,
		xhp=3,
		move=1,
		scene=2
	}
	update_scene=up_order[p.scene]
	draw_scene=drw_order[p.scene]
end

function _update()
	update_scene()
end

function _draw()
	cls()
	draw_scene()
end
-->8
--controls
tsize=8

function update_menu()
 if btnp(🅾️) then
 	sfx(0)
 	draw_scene=draw_story
 	update_scene=update_story
 end
end

function update_story()
	if btnp(🅾️) then
		print('proceed')
	end
end

function update_level()
	local function msfx()
		sfx(1)
	end
	-- move ⬅️ and ➡️
	if btnp(➡️) then
		p.x+=p.move*tsize
		msfx()
	end
	if btnp(⬅️) then
		p.x-=p.move*tsize
		msfx()
	end
	
	-- move ⬆️ and ⬇️
	if btnp(⬇️) then
		p.y+=p.move*tsize
		msfx()
	end
	if btnp(⬆️) then
	 p.y-=p.move*tsize
		msfx()
	end
end
-->8
--main menu
function draw_menu()
	print('♥ hunk-munculus ♥',27,40,8)
	print('learning how to love.',24,50,5)
	print('press 🅾️ to start',31,74,9)
end

function draw_story()
	local s={
		'you are a homunculus, newly born.',
		'\n',
		'your creator has high hopes for you.',
		'\n',
		'unlike other homunculi, you have a quest.',
		'\n',
		'a quest to learn all you can...',
		'\n',
		'about love!'
	}

	foreach(s,print)
	
	print('🅾️ to skip', 80,120,8)
	
end

function draw_level()
	local function load_level(lvl)
		map(0,0,0,40,16,7)
		spr(p.sprt,p.x,p.y)
	end
	
	load_level()
end
