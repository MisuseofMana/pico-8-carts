pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--base template
--shinbone♥

function _init()
	--menu
	m={}
	
	v={
		sc=60,
		bad=8,
		good=10
	}
	
	--game
	g={
		u=u_menu,
		d=d_menu,
		scene=1,
		tick=0,
	}

	--levels
	l={}
	
	--player
	p={}
end

function _update()
	g.u()
	g.tick+=1
	if g.tick>30 then
		g.tick=0
	end
end

function _draw()
	cls()
	g.d()
end
-->8
--main menu
function u_menu()
	if btnp(❎) then
		change_scene(1)
	end
end

function d_menu()
	rectfill(8,8,120,120,1)
	
	local t="main menu"
	print(t,hc(t),63,7)
	t="press ❎"
	print(t,hc(t,1),71)
end
-->8
--game
function u_game()
	if btnp(🅾️) then
		change_scene(-1)
	end
end

function d_game()
	dice({l=52,h=54},{l=59,h=61})
	dice({l=62,h=64},{l=59,h=61})
	local t="stop dice ❎"
	print(t,hc(t,1),72)
end

function instruction()
	rectfill(8,8,120,120,2)
	local t="game screen"
	print(t,hc(t),63,7)
	t="back to menu 🅾️"
	print(t,hc(t,2),71,7)
end

function dice(xr,yr)
	local face=rnd({1,2,3,4,5,6})
		spr(
			face,
			rrng(xr.h,xr.l),
			rrng(yr.h,yr.l)
		)
end
-->8
--scene navigation

function change_scene(i)
	local scenes={
		{u=u_menu,d=d_menu},
		{u=u_game,d=d_game},
	}
	g.scene+=i
	g.u=scenes[g.scene].u
	g.d=scenes[g.scene].d
end
-->8
-- utilities

function hc(t,g) --center text
	local base=64-#t*2
	if g then
		base-=g*2
	end
	return base
end

function rrng(h,l)
	return flr(rnd(h-l+1))+l
end
