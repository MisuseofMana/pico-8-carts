pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--base template
--shinbone♥

function _init()
	--menu
	m={}
	
	v={
		sc=60,
		bad=8,
		good=10
	}
	
	--game
	g={
		u=u_menu,
		d=d_menu,
		scene=1
	}

	--levels
	l={}
	
	--player
	p={}
end

function _update()
	g.u()
end

function _draw()
	cls()
	g.d()
end
-->8
--main menu
function u_menu()
	if btnp(❎) then
		change_scene(1)
	end
end

function d_menu()
	rectfill(8,8,120,120,1)
	
	local t="main menu"
	print(t,hc(t),63,7)
	t="press ❎"
	print(t,hc(t,1),71)
	local ofst=-12
	for i=1,4 do
		spr(i,v.sc+ofst,v.sc+20)
		ofst+=8
	end
end
-->8
--game
function u_game()
	if btnp(🅾️) then
		change_scene(-1)
	end
end

function d_game()
	rectfill(8,8,120,120,2)
	local t="game screen"
	print(t,hc(t),63,7)
	t="back to menu 🅾️"
	print(t,hc(t,2),71,7)
	local ofst=-12
	for i=1,4 do
		spr(i,v.sc+ofst,v.sc+20,1,1,true,false)
		ofst+=8
	end
end
-->8
--scene navigation

function change_scene(i)
	local scenes={
		{u=u_menu,d=d_menu},
		{u=u_game,d=d_game},
	}
	g.scene+=i
	g.u=scenes[g.scene].u
	g.d=scenes[g.scene].d
end
-->8
-- utilities

function hc(t,g) --center text
	local base=64-#t*2
	if g then
		base-=g*2
	end
	return base
end
