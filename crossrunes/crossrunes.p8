pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--crossrunes
--by shinbone★
function _init()
	why=""
	version=1
	cartdata("shinbone_crossrune_"..version)
	--game definition
	g={
		scene=1,
		char=char.mage,
		draw=draw_menu,
		update=update_menu,
		timing=0,
		tlimit=99,
		second_tick=30,
		game_over=false
	}
	--level data
	l={
		mana=0,
		score=0,
		target=100,
		runes={},
		solution={},
		sol_leng=5,
		picker={x=0,y=0}
	}
	--menu options
	m={
		opt={
		 {t="new game",f=new_game,a=true},
			{t="load game",f=load_game,a=false},	
			{t="options",f=options,a=false}
		},
		selection=1
	}
	handle_menu_options()
end

function _update()
	g.timing+=0.1
	if (g.timing>1) g.timing=0
	g.update()
end

function _draw()
	cls()
	g.draw()
	--debug printing
	print(why,0,0)
end
