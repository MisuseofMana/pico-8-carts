__lua__
--crossrunes
--by shinbone★

function _init()
	why=""
	version=1
	cartdata("shinbone_crossrune_"..version)
	--particle effects
	effects={}
	
	--game definition
	g={
		scene=1,
		draw=draw_menu,
		update=update_menu,
		timing=0,
		tlimit=5,
		second_tick=30,
		talk_timer=0,
		game_over=false
	}
	--level data
	l={
		char=char.baldy,
		mana=100,
		max_mana=100,
		score=0,
		size=8,
		target=100,
		runes={},
		solution={},
		picker={x=9,y=9},
		selected={}
	}
	--menu options
	m={
		opt={
		 {t="new game",f=new_game,a=true},
			{t="load game",f=load_game,a=false},	
			{t="options",f=options,a=false}
		},
		selection=1
	}
	handle_menu_options()
end

function _update()
	g.timing+=0.1
	if g.timing>10.5 then
		g.timing=rnd({1,2,3,4,5,6})
	end
	g.update()
	update_fx()
end

function _draw()
	cls()
	g.draw()
	--debug printing
	print(why,0,0)
end

