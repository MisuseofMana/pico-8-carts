--drawing
function draw_menu()
	local l={
		c=196,
		r=197,
		o=198,
		s=199,
		u=200,
		n=212,
		e=213,
	}
	local title={
		l.c,l.r,l.o,l.s,
		l.s,l.r,l.u,l.n,
		l.e,l.s
	}
	rectfill(0,0,127,127,13)
	rectfill(16,16,116,108,1)
	map(0,0,8,12,15,13)
	local txp=19
	for v in all(title) do
		spr(v,txp,58)
		txp+=9
	end
	
	local xp=45
	local yp=72
	local col=7
	for opt in all(m.opt) do
		if opt.a==true then
			col=9
			spr(226,xp-10,yp-1)
		else	
			col=7
		end
		print(opt.t,hc_txt(opt.t),yp,col)
		yp+=10
	end
end

function draw_ui()
	rectfill(0,0,88,88,1)
	local h=8
	for i=1,11 do
		line(h,0,h,128,0)--horizontal
		line(0,h,128,h,0)--vertical
		h+=9
	end
	rectfill(0,90,127,127,2)
	rect(0,90,127,127,6)
end

function draw_char()
	rectfill(2,92,34,125,0)
	rect(2,92,34,125,6)
	local c=l.char
	local em=c.emote
	spr(c.port,3,93,4,4)
	if l.char.mien=="angry" then
		spr(em.angry.e,11,101,3,1)
		spr(em.angry.m,19,109)
	end
	--blink timer
	if g.timing>10 then
		spr(c.blink,11,101,3,1)
	end
	--side-eye
	if (g.timing==mid(2,g.timing,5)) then
		spr(em.ignore.e,11,101,3,1)
	end
	
	if g.talk_timer>0 then
		if g.talk_timer%10<5 then
			spr(c.talk,19,109)
		end
	end
end

function draw_timer()
	spr(136,91,0)
	local num_str=tostr(g.tlimit)
	local chars=split(num_str,"")
	local cleng=#chars
	--init xpos based on cleng
	local xpos=112-((cleng*8)/2)
	for c in all(chars) do
		spr(get_numsp(c),xpos,0)
		xpos+=8
	end
end

function draw_score()
	local score=tostr(l.score)
	local chars=split(score,"")
	local cleng=#chars
	local xpos=107-((cleng*8)/2)
	for c in all(chars) do
		pal({[7]=9})
		spr(get_numsp(c),xpos,78)
		pal()
		xpos+=8
	end
end

function draw_orb()
	spr(get_orb(),99,20,2,2)
	local mana=tostr(l.mana)
	local chars=split(mana,"")
	local cleng=#chars
	local xpos=107-((cleng*8)/2)
	for c in all(chars) do
		pal({[7]=12})
		spr(get_numsp(c),xpos,38)
		pal()
		xpos+=8
	end
end

function draw_dialog(str)
	local c=l.char
	local str=c.a_dialog
	local words=split(str, " ")
	local pointer=0
	local pstr=""
	for w in all(words) do
		if pointer+(#w+1)>20 then
			pstr=pstr.."\n"
			pointer=0
		end
		pstr=pstr.." "..w
		pointer+=#w+1
	end
	
	print(pstr,34,94,7)
end

function draw_runes()
	for r in all(l.runes) do
		pal({[7]=r.c})
		spr(r.sp,r.x,r.y)
		pal()
	end
end

function draw_solution()
	rectfill(36,114,125,125,5)
	rect(36,114,125,125,6)
	local xpos=38
	local some_sel=#l.selected>0
	for i, r in ipairs(l.solution) do
		local in_range=#l.selected>=i
		if some_sel and in_range then
			if runes_match(r,l.selected[i]) then
				ovalfill(xpos,116,xpos+7,116+7,11)
			else
				ovalfill(xpos,116,xpos+7,116+7,8)
			end
		end
		pal({[7]=r.c})
		spr(r.sp,xpos,116)
		pal()
		xpos+=8
	end
end

function draw_cursor()
	local p=l.picker
	local t=g.second_tick
	if t<15 then
		rect(p.x-1,p.y-1,p.x+8,p.y+8,7)
	else
		rect(p.x-2,p.y-2,p.x+9,p.y+9,7)
	end
end

function draw_path()
	local colr=12
	local s=l.selected
	for i, r in ipairs(s) do
		if i==1 then
			rectfill(r.x+1,r.y+1,r.x+6,r.y+6,colr)
			line(r.x+4,r.y-1,r.x+8,r.y+3,colr)
			line(r.x+8,r.y+4,r.x+4,r.y+8)
			line(r.x+3,r.y+8,r.x-1,r.y+4)
			line(r.x-1,r.y+3,r.x+3,r.y-1)
		end
		if i>1 then
			local p=s[i-1]
			rectfill(r.x+1,r.y+1,r.x+6,r.y+6,colr)
			line(p.x+3,p.y+3,r.x+3,r.y+3,colr)
			line(r.x+4,r.y-1,r.x+8,r.y+3,colr)
			line(r.x+8,r.y+4,r.x+4,r.y+8)
			line(r.x+3,r.y+8,r.x-1,r.y+4)
			line(r.x-1,r.y+3,r.x+3,r.y-1)
		end
	end
end

function draw_game()
	draw_ui()
	draw_char()
	draw_timer()
	draw_orb()
	draw_dialog()
	draw_path()
	draw_runes()
	draw_solution()
	draw_cursor()
	draw_score()
	draw_fx()
end
