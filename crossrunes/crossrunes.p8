--updating

function update_menu()
	local bs=tostr(btnp())
	local bn=btnp()
	if bn==0 then return end
	
	local btns={
		["4"]=-1,--up
		["8"]=1,--down
	}
	
	if btnp(❎) then --❎
		m.opt[m.selection].f()
	end
	
	if btns[bs] then
		sfx(0)
 	m.selection+=btns[bs]
 end
	
	if m.selection>#m.opt then
		m.selection=1
	elseif m.selection<=0 then
		m.selection=#m.opt
	end
	
	for i,v in ipairs(m.opt) do
		if i==m.selection then
			v.a=true
		else
			v.a=false
		end
	end
end

function handle_game_input(bp)
	local bs=tostr(bp)
	
	local btns={
		["1"]={x=-1,y=0},--left
		["2"]={x=1,y=0},--right
		["4"]={x=0,y=-1},--up
		["8"]={x=0,y=1},--down
	}
	
	if btnp(❎) then
		click_rune(l.picker)
	end
	
	if btnp(🅾️) then
		if #l.selected>0 then
			sfx(8)
			deli(l.selected, #l.selected)
			add_mana(1)
		end
	end
	
	if btns[bs] then
		local x=btns[bs].x
		local y=btns[bs].y
		local xdest=l.picker.x+(x*9)
		local ydest=l.picker.y+(y*9)
		local np={x=xdest,y=ydest}
		
		sfx(rnd({1,2,3}))
		l.picker.x=mid(9,xdest,l.size*9)
		l.picker.y=mid(9,ydest,l.size*9)
 end
end

function update_game()
	tick_down()
	handle_game_input(btnp())
	update_fx()
	if g.talk_timer>0 then
		g.talk_timer-=1
	end
end
