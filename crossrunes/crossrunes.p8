--lookups

--[[
	number sprites for the games
	big timer display
]]
num_sp={
	[1]=192,[2]=193,[3]=194,
	[4]=195,[5]=208,[6]=209,
	[7]=210,[8]=211,[9]=224,
	[0]=225
}

function get_numsp(key)
	return num_sp[key]
end

--[[
	character sprite reference
	by character names
]]
char={
	mage={
		port=9,
		talk=61,
		blink=13,
		emote={
			angry={m=62,e=29},
			ignore={m=nil,e=45},
			happy={m=63,e=nil}
		},
		intro="ready for your enchantment lesson today?",
		ending="fantastic training, i'm impressed you managed to get this far.",
		failed="you get failing marks for today.",
		dialog={
			angry={
				"that's not right.",
				"what are you doing?",
				"go back to the basics..."
			},
			ignore={
				"ugh...",
				"oh, come on now.",
				"sloppy tracing..."
			},
			happy={
				"that's great, good work.",
				"excellent literacy.",
				"keep up the momentum."
			}
		}
	},
	baldy={
		port=73
	},
	gob={
		port=137
	},
	seer={
		port=201
	}
}

function get_char(key)
	return char[key]
end

orb={
	128,130,132,134,
	160,162,164
}

runes={
	1,2,3,4,5,6,7,8,
	16,17,18,19,20,21,22,23,24,
	32,33,34,35,36,37,38,39,40,
	48,49,50,51,52,53,54,55,56
}

rune_c={
	7,8,9,11,12
}
-->8
--drawing
function draw_menu()
	local l={
		c=196,
		r=197,
		o=198,
		s=199,
		u=200,
		n=212,
		e=213,
	}
	local title={
		l.c,l.r,l.o,l.s,
		l.s,l.r,l.u,l.n,
		l.e,l.s
	}
	rectfill(0,0,127,127,13)
	rectfill(16,16,116,108,1)
	map(0,0,8,12,15,13)
	local txp=19
	for v in all(title) do
		spr(v,txp,58)
		txp+=9
	end
	
	local xp=45
	local yp=72
	local col=7
	for opt in all(m.opt) do
		if opt.a==true then
			col=9
			spr(226,xp-10,yp-1)
		else	
			col=7
		end
		print(opt.t,hc_txt(opt.t),yp,col)
		yp+=10
	end
end

function draw_ui()
	rectfill(0,0,88,88,1)
	local h=8
	for i=1,11 do
		line(h,0,h,128,0)--horizontal
		line(0,h,128,h,0)--vertical
		h+=9
	end
	rectfill(0,90,127,127,2)
	rect(0,90,127,127,6)
end

function draw_char()
	rectfill(2,92,34,125,0)
	rect(2,92,34,125,6)
	spr(9,3,93,4,4)
	if g.timing>10 then
		spr(13,11,101,3,1)
	end
	if g.timing>10.5 then
		g.timing=rnd({1,2,3,4,5,6})
	end
	if g.timing>5 then
		spr(61,19,109)
	end
end

function draw_timer()
	local num_str=tostr(g.tlimit)
	local chars=split(num_str,"")
	local cleng=#chars
	--init xpos based on cleng
	local xpos=107-((cleng*8)/2)
	for c in all(chars) do
		spr(get_numsp(c),xpos,0)
		xpos+=8
	end
end

function draw_orb()
	spr(get_orb(),99,10,2,2)
end

function draw_dialog(str)
	local str=char_state().intro
	local words=split(str, " ")
	local pointer=0
	local pstr=""
	for w in all(words) do
		if pointer+(#w+1)>20 then
			pstr=pstr.."\n"
			pointer=0
		end
		pstr=pstr.." "..w
		pointer+=#w+1
	end
	
	print(pstr,34,94,7)
end

function draw_runes()
	for r in all(l.runes) do
		pal({[7]=r.c})
		spr(r.sp,r.x,r.y)
		pal()
	end
end

function draw_solution()
	local xpos=80-((l.sol_leng*8)/2)
	for r in all(l.solution) do
		pal({[7]=r.c})
		spr(r.sp,xpos,118)
		pal()
		xpos+=8
	end
end

function draw_cursor()
	spr(116,l.picker.x,l.picker.y)
end

function draw_game()
	draw_ui()
	draw_char()
	draw_timer()
	draw_orb()
	draw_dialog()
	draw_runes()
	draw_solution()
	draw_cursor()
end
-->8
--updating

function update_menu()
	local bs=tostr(btnp())
	local bn=btnp()
	if bn==0 then return end
	
	local btns={
		["4"]=-1,--up
		["8"]=1,--down
	}
	
	if btnp(❎) then --❎
		m.opt[m.selection].f()
	end
	
	--early exit for no saved game
	if (#m.opt==1) return
	
	if btns[bs] then
		sfx(0)
 	m.selection+=btns[bs]
 end
	
	if m.selection>#m.opt then
		m.selection=1
	elseif m.selection<=0 then
		m.selection=#m.opt
	end
	
	for i,v in ipairs(m.opt) do
		if i==m.selection then
			v.a=true
		else
			v.a=false
		end
	end
end

function handle_game_input(bp)
	local bs=tostr(bp)
	
	local btns={
		["1"]=-1,--left
		["2"]=1,--right
		["4"]=-1,--up
		["8"]=1,--down
	}
	
	if btnp(🅾️) then
		l.score+=10
	end
end

function update_game()
	tick_down()
	handle_game_input(btnp())
end
-->8
--save & menu
function save_game()
	dset(0,level)--level
	dset(1,game)--game
	dset(2,scene)--scene
end

function new_game()
	init_level()
	g.draw=draw_game
	g.update=update_game
end

function load_game()
	--todo: handle loading data
	new_game()
end

function options()
	--todo: handle options
end

function handle_menu_options()
	if dget(0)==0 then
		deli(m.opt,2)
	end
end


-->8
--utilities

function hc_txt(txt)
 --gets horizontal center
 --for the provided text
 local tl=#txt
 local tw=tl*4
 return 64-tw/2
end

--tick down to track seconds
function tick_down()
	if g.tlimit==0 then
		g.game_over=true
		return
	end
	g.second_tick -=1
	if g.second_tick==0 then
		g.second_tick=30
		g.tlimit-=1
	end
end

function char_state()
	--[[todo:
	use game data to determine
	the character portrait and
	dialog to display.
	
	should this be event or data
	driven? leaning towards data.
	take into account mana values,
	errors, etc. all events change
	data and the data determines
	how the character looks and 
	what dialog is displayed	
	]]
	return g.char
end

function get_orb()
	local s=l.score
	local division=l.target/#orb
	local i=l.score\division+1
	if (i>#orb) i=#orb	
	return orb[i]
end

function init_runes()
	--[[should genertate runes
	for all the spaces in the
	board. ]]
	local xsize=9
	local ysize=9
	for y=0, xsize do
		for x=0, ysize do
			add(l.runes, {
				sp=rnd(runes),
				x=x*9,
				y=y*9,
				c=rnd(rune_c)
			})
		end
	end
end

function gen_rune_solution()
	l.solution={}
	local ret={}
	for i=1, l.sol_leng do
		add(l.solution, l.runes[i])
	end
end

function init_level()
	init_runes()
	gen_rune_solution()
end


