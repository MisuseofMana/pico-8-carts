--utilities

function hc_txt(txt)
 --gets horizontal center
 --for the provided text
 local tl=#txt
 local tw=tl*4
 return 64-tw/2
end

--tick down to track seconds
function tick_down()
	if g.tlimit==0 and not g.game_over then
		g.game_over=true
		set_mien("failed")
	end
	if (g.game_over) return
	g.second_tick-=1
	if g.second_tick==0 then
		g.second_tick=30
		g.tlimit-=1
	end
end

function get_orb()
	local division=l.max_mana/#orb
	local i=l.mana\division+1
	if (i>#orb) i=#orb	
	return orb[i]
end

function init_runes()
	--[[should genertate runes
	for all the spaces in the
	board. ]]
	for y=1, l.size do
		for x=1, l.size do
			add(l.runes, {
				sp=rnd(runes),
				x=x*9,
				y=y*9,
				selected=false,
				c=rnd(l.char.rune_c)
			})
		end
	end
end

function gen_rune_solution()
	l.solution={}
	local runes={}
	for r in all(l.runes) do
		add(runes,r)
	end
	for i=1, l.char.sol_leng do
		local t=del(runes,rnd(runes))
		add(l.solution,t)
	end
end

function rune_is_selected(pos)
	local x=pos.x
	local y=pos.y
	for r in	all(l.selected) do
		local foundx=r.x==x
		local foundy=r.y==y
		if foundx and foundy then
			return true
		end
	end
	return false
end

function pos_are_adj(p1,p2)
	local xdif=abs(p1.x-p2.x)
	local ydif=abs(p1.y-p2.y)
	local dif=xdif+ydif
	why=dif
	if dif>=0 and dif<=9*3 then
		return true
	end
	return false
end

function click_rune(pos)
	local x=pos.x
	local y=pos.y
	for r in	all(l.runes) do
		local foundx=r.x==x
		local foundy=r.y==y
		if foundx and foundy then
			local s=l.selected
			if #s>0 then
				sfx(4)
				add(l.selected, r)
				reduce_mana(2)
				
			--[[
				if no runes are selected
				can select any rune
			]]
			elseif #s==0 then
				sfx(4)
				add(l.selected, r)
				reduce_mana(2)
			end
			check_valid_solution()
		end
	end
end

function runes_match(r1,r2)
	local cm=r1.c==r2.c
	local sm=r1.sp==r2.sp
	return cm and sm
end

function pick_pos()
	return {
		x=l.picker.x,
		y=l.picker.y
	}
end

function check_valid_solution()
	local valid=true
	if #l.solution != #l.selected then
		return
	end
	for i,r in ipairs(l.selected) do
		if r.sp != l.solution[i].sp then
			valid=false
		end
	end
	if valid==true then
		l.score+=l.char.sol_leng
		add_mana(l.char.sol_leng*2)
		gen_rune_solution()
		l.selected={}
		set_mien("happy")
	else
		fire()
		reduce_mana(10)
		gen_rune_solution()
		l.selected={}
		if l.char.mien=="ignore" then
			set_mien("angry")
		else
			set_mien("ignore")
		end
	end
end



function can_move_to(np)
	local ppos=pick_pos()
	local s=l.selected
	if #s>0 then
		ppos=s[#s]		
	end
	return pos_are_adj(np,ppos)	
end

function init_level()
	init_runes()
	gen_rune_solution()
end

function grade_level()
	--[[
		show game over screen
		display grade
		show report
	]]
end

function reduce_mana(n)
	l.mana-=n
	if l.mana<=0 then
		l.mana=0
		set_mien("failed")
		grade_level()
	end
end

function add_mana(n)
	l.mana+=n
	if l.mana>l.max_mana then
		l.mana=l.max_mana
	end
end

function in_rng(t,a,b)
	return t==mid(a,t,b)
end

function set_mien(to)
	l.char.mien=to
	set_dialog(to)
end

function animate_talk()
	g.talk_timer=40
	sfx(rnd(l.char.talksounds))
end

function set_dialog(m)
	l.char.a_dialog=rnd(l.char.dialog[m])
	animate_talk()
end
