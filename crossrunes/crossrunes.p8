--save & level transition
function save_game()
	dset(0,level)--level
	dset(1,game)--game
	dset(2,scene)--scene
end

function new_game()
	init_level()
	set_dialog("intro")
	g.draw=draw_game
	g.update=update_game
end

function load_game()
	--todo: handle loading data
	new_game()
end

function options()
	--todo: handle options
end

function handle_menu_options()
	if dget(0)==0 then
		deli(m.opt,2)
	end
end


